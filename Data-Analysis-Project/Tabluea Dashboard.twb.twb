      <aliases enabled='yes' />
      <column caption='Pollution Index' datatype='real' name='[Calculation_0971697703202816]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[pm25] * 0.5 + [pm10] * 0.3 + [no2] * 0.2' />
      </column>
      <column caption='Rush hour flag' datatype='string' name='[Calculation_0971697703620609]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEPART(&apos;hour&apos;,[date_time]) IN (8,9,10,18,19,20) THEN &quot;Rush Hour&quot; ELSE &quot;Normal&quot; END' />
      </column>
      <column caption='Avg speed eficiency' datatype='real' name='[Calculation_0971697703813122]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[avg_speed] / 40' />
      </column>
      <column caption='Traffic (0-1)' datatype='real' name='[Calculation_0971697720205315]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[vehicle_count] / { FIXED : MAX([vehicle_count]) }' />
      </column>
      <column caption='Pollution (0-1)' datatype='real' name='[Calculation_0971697721585668]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[pm25] / { FIXED : MAX([pm25]) }' />
